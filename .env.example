# Google Cloud project that owns the BigQuery ML model and runs query jobs.
GOOGLE_CLOUD_PROJECT=your-google-cloud-project-id

# Optional fallback project ID. Usually this can match GOOGLE_CLOUD_PROJECT.
GOOGLE_PROJECT_ID=your-google-cloud-project-id

# Path to your service account JSON key.
# Use a relative path if the file is in the project folder, or an absolute path.
# Do not commit the real JSON key.
GOOGLE_APPLICATION_CREDENTIALS=your-service-account-file.json

# BigQuery dataset that contains your trained BigQuery ML model.
BQ_MODEL_DATASET=bmAI
